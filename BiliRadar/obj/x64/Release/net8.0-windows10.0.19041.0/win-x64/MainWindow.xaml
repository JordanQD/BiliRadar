<?xml version="1.0" encoding="utf-8"?>
<Window x:ConnectionId='1'
    x:Class="BiliRadar.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:BiliRadar.Models"
    Title="BiliRadar">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid x:ConnectionId='2'
        x:Name="RootGrid"
        Width="348"
        MinHeight="100"
        Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:ConnectionId='3'
            x:Name="MainContainer"
            Grid.RowSpan="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
        <Grid Padding="16,14,12,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="2">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="BiliRadar" />
                <TextBlock x:ConnectionId='16'
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                 />
            </StackPanel>

            <Button x:ConnectionId='14'
                Grid.Column="1"
                Width="34"
                Height="34"
                Padding="0"
                                           
                Style="{StaticResource SubtleButtonStyle}">
                <FontIcon FontSize="15" Glyph="&#xE72C;" />
            </Button>

            <Button x:ConnectionId='15'
                Grid.Column="2"
                Width="34"
                Height="34"
                Padding="0"
                                        
                Style="{StaticResource SubtleButtonStyle}">
                <FontIcon FontSize="14" Glyph="&#xE711;" />
            </Button>
        </Grid>

        <Grid Grid.Row="1" Padding="12,4,12,10" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Padding="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="未读更新" />
                    <TextBlock x:ConnectionId='13'
                        FontSize="26"
                        FontWeight="SemiBold"
                                                                 />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="1"
                Padding="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="关注人数" />
                    <TextBlock x:ConnectionId='12'
                        FontSize="26"
                        FontWeight="SemiBold"
                                                                    />
                </StackPanel>
            </Border>
        </Grid>

        <ListView x:ConnectionId='4'
            Grid.Row="2"
            Padding="6,0"
                                                       
            SelectionMode="None">
            <ListView.Header>
                <TextBlock
                    Margin="10,0,0,8"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="最近视频" />
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate                                   >
                    <Grid x:ConnectionId='8' Padding="8,8" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Width="32"
                            Height="32"
                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                            CornerRadius="7">
                            <FontIcon
                                FontSize="16"
                                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                Glyph="&#xE714;" />
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock x:ConnectionId='10'
                                FontWeight="SemiBold"
                                                     
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap" />
                            <TextBlock x:ConnectionId='11'
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap" />
                        </StackPanel>

                        <TextBlock x:ConnectionId='9'
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                         />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid
            Grid.Row="3"
            Padding="12,8,12,12"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ProgressRing x:ConnectionId='5'
                Width="18"
                Height="18"
                HorizontalAlignment="Left"
                                                          
                                                                     />

            <Button x:ConnectionId='6'
                Grid.Column="1"
                MinWidth="92"
                                           
                Content="立即刷新" />
        </Grid>
        </Grid>
    </Grid>
</Window>

