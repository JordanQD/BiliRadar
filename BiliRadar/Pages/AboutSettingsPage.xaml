<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BiliRadar.Pages.AboutSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls">

    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Style
            x:Key="SettingsSectionHeaderTextBlockStyle"
            BasedOn="{StaticResource BodyStrongTextBlockStyle}"
            TargetType="TextBlock">
            <Setter Property="Margin" Value="1,28,0,6" />
        </Style>
    </Page.Resources>

    <ScrollViewer
        x:Name="SettingsScrollViewer"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <StackPanel
            MaxWidth="920"
            Padding="40,32"
            HorizontalAlignment="Stretch"
            Spacing="{StaticResource SettingsCardSpacing}">
            <StackPanel.ChildrenTransitions>
                <EntranceThemeTransition FromVerticalOffset="36" />
                <RepositionThemeTransition IsStaggeringEnabled="False" />
            </StackPanel.ChildrenTransitions>

            <TextBlock
                Margin="0,0,0,12"
                Style="{ThemeResource TitleTextBlockStyle}"
                Text="关于" />

            <controls:SettingsCard HorizontalContentAlignment="Stretch">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="72"
                        Height="72"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        CornerRadius="{ThemeResource OverlayCornerRadius}">
                        <Image
                            Width="44"
                            Height="44"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Source="/Assets/Square44x44Logo.targetsize-44_altform-unplated.png" />
                    </Border>
                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Spacing="4">
                        <TextBlock
                            Style="{ThemeResource TitleTextBlockStyle}"
                            Text="BiliRadar" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="一个放在任务栏托盘里的 B 站动态雷达。"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </controls:SettingsCard>

            <TextBlock
                Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                Text="应用信息" />
            <controls:SettingsCard
                Description="当前安装的 BiliRadar 版本。"
                Header="版本">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE946;" />
                </controls:SettingsCard.HeaderIcon>
                <TextBlock
                    x:Name="VersionText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </controls:SettingsCard>
            <controls:SettingsCard
                Description="应用包清单中的发布者名称。"
                Header="发布者">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE77B;" />
                </controls:SettingsCard.HeaderIcon>
                <TextBlock
                    x:Name="PublisherText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </controls:SettingsCard>
            <controls:SettingsCard
                Description="本机设置和登录状态保存在应用本地数据中。"
                Header="数据位置">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE838;" />
                </controls:SettingsCard.HeaderIcon>
                <TextBlock
                    x:Name="DataLocationText"
                    MaxWidth="420"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextTrimming="CharacterEllipsis" />
            </controls:SettingsCard>
        </StackPanel>
    </ScrollViewer>
</Page>
