<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BiliRadar.Pages.AboutSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls">

    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Style
            x:Key="SettingsSectionHeaderTextBlockStyle"
            BasedOn="{StaticResource BodyStrongTextBlockStyle}"
            TargetType="TextBlock">
            <Setter Property="Margin" Value="1,28,0,6" />
        </Style>
    </Page.Resources>

    <ScrollViewer
        x:Name="SettingsScrollViewer"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <StackPanel
            Width="1064"
            MaxWidth="1064"
            Padding="40,32"
            HorizontalAlignment="Center"
            Spacing="{StaticResource SettingsCardSpacing}">
            <StackPanel.ChildrenTransitions>
                <RepositionThemeTransition />
            </StackPanel.ChildrenTransitions>

            <TextBlock
                Margin="0,0,0,12"
                Style="{ThemeResource TitleTextBlockStyle}"
                Text="关于" />

            <controls:SettingsExpander
                x:Name="AboutExpander"
                Margin="0,0,0,36"
                Description="一个放在任务栏托盘里的 B 站动态雷达。"
                Header="BiliRadar"
                IsExpanded="True">
                <controls:SettingsExpander.HeaderIcon>
                    <BitmapIcon
                        ShowAsMonochrome="False"
                        UriSource="/Assets/Square44x44Logo.targetsize-24_altform-unplated.png" />
                </controls:SettingsExpander.HeaderIcon>
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    IsTextSelectionEnabled="True"
                    Text="{x:Bind Version}" />
                <controls:SettingsExpander.Items>
                    <controls:SettingsCard
                        x:Name="CloneRepositoryCard"
                        Click="CloneRepositoryCard_Click"
                        Header="克隆此仓库"
                        IsClickEnabled="True">
                        <TextBlock
                            x:Name="GitCloneTextBlock"
                            FontFamily="Consolas"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            IsTextSelectionEnabled="True"
                            Text="git clone https://github.com/JordanQD/BiliRadar.git" />
                        <controls:SettingsCard.ActionIcon>
                            <FontIcon Glyph="&#xE8C8;" />
                        </controls:SettingsCard.ActionIcon>
                    </controls:SettingsCard>
                    <controls:SettingsCard
                        x:Name="IssueRequestCard"
                        Click="IssueRequestCard_Click"
                        Header="提交问题或功能建议"
                        IsClickEnabled="True">
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="JordanQD/BiliRadar" />
                        <controls:SettingsCard.ActionIcon>
                            <FontIcon Glyph="&#xE8A7;" />
                        </controls:SettingsCard.ActionIcon>
                    </controls:SettingsCard>
                    <controls:SettingsCard
                        HorizontalContentAlignment="Left"
                        ContentAlignment="Vertical"
                        Header="依赖与参考">
                        <StackPanel
                            Margin="-12,0,0,0"
                            Orientation="Vertical">
                            <HyperlinkButton
                                Content="Richasy/Bili.Copilot"
                                NavigateUri="https://github.com/Richasy/Bili.Copilot" />
                            <HyperlinkButton
                                Content="Richasy/bili-kernel"
                                NavigateUri="https://github.com/Richasy/bili-kernel" />
                            <HyperlinkButton
                                Content="microsoft/WindowsAppSDK"
                                NavigateUri="https://github.com/microsoft/WindowsAppSDK" />
                            <HyperlinkButton
                                Content="microsoft/WinUI-Gallery"
                                NavigateUri="https://github.com/microsoft/WinUI-Gallery" />
                            <HyperlinkButton
                                Content="microsoft/microsoft-ui-xaml"
                                NavigateUri="https://github.com/microsoft/microsoft-ui-xaml" />
                            <HyperlinkButton
                                Content="CommunityToolkit/Windows"
                                NavigateUri="https://github.com/CommunityToolkit/Windows" />
                        </StackPanel>
                    </controls:SettingsCard>
                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>
            <TextBlock
                x:Name="AboutStatusText"
                Margin="1,8,0,0"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
