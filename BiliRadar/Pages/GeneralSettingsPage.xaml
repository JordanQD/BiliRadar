<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BiliRadar.Pages.GeneralSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls">

    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>
        <Style
            x:Key="SettingsSectionHeaderTextBlockStyle"
            BasedOn="{StaticResource BodyStrongTextBlockStyle}"
            TargetType="TextBlock">
            <Setter Property="Margin" Value="1,28,0,6" />
        </Style>
    </Page.Resources>

    <ScrollViewer
        x:Name="SettingsScrollViewer"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <StackPanel
            MaxWidth="920"
            Padding="40,32"
            HorizontalAlignment="Stretch"
            Spacing="{StaticResource SettingsCardSpacing}">
            <StackPanel.ChildrenTransitions>
                <EntranceThemeTransition FromVerticalOffset="36" />
                <RepositionThemeTransition IsStaggeringEnabled="False" />
            </StackPanel.ChildrenTransitions>

            <TextBlock
                Margin="0,0,0,12"
                Style="{ThemeResource TitleTextBlockStyle}"
                Text="通用" />

            <TextBlock
                Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                Text="启动" />
            <controls:SettingsCard
                Description="登录 Windows 后自动启动 BiliRadar。"
                Header="开机后自动运行">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE7E8;" />
                </controls:SettingsCard.HeaderIcon>
                <ToggleSwitch
                    x:Name="AutoStartSwitch"
                    AutomationProperties.AutomationId="AutoStartSwitch"
                    Toggled="AutoStartSwitch_Toggled" />
            </controls:SettingsCard>
            <InfoBar
                x:Name="StartupInfoBar"
                Margin="0,4,0,0"
                IsClosable="False"
                IsOpen="False"
                Severity="Informational" />

            <TextBlock
                Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                Text="登录选项" />
            <controls:SettingsCard
                Description="BiliRadar 已经在后台运行时，从开始菜单再次打开后的行为。"
                Header="重复打开应用时">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8AB;" />
                </controls:SettingsCard.HeaderIcon>
                <ComboBox
                    x:Name="RunningLaunchActionBox"
                    Width="220"
                    AutomationProperties.AutomationId="RunningLaunchActionBox"
                    SelectionChanged="RunningLaunchActionBox_SelectionChanged">
                    <ComboBoxItem Content="打开设置" />
                    <ComboBoxItem Content="打开哔哩哔哩网页" />
                </ComboBox>
            </controls:SettingsCard>
            <controls:SettingsCard
                Header="Bilibili 登录状态"
                HorizontalContentAlignment="Stretch">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE77B;" />
                </controls:SettingsCard.HeaderIcon>
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <PersonPicture
                        x:Name="AvatarPicture"
                        Width="48"
                        Height="48"
                        VerticalAlignment="Center"
                        Initials="BR" />
                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Spacing="2">
                        <TextBlock
                            x:Name="AccountNameText"
                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                            Text="未登录" />
                        <TextBlock
                            x:Name="AccountDetailText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="网页登录后会保存登录状态，用于刷新关注动态。"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            x:Name="SignInButton"
                            AutomationProperties.AutomationId="SignInButton"
                            Click="SignInButton_Click"
                            Content="网页登录" />
                        <Button
                            x:Name="RefreshStatusButton"
                            AutomationProperties.AutomationId="RefreshStatusButton"
                            Click="RefreshStatusButton_Click"
                            Content="刷新" />
                        <Button
                            x:Name="SignOutButton"
                            AutomationProperties.AutomationId="SignOutButton"
                            Click="SignOutButton_Click"
                            Content="清除" />
                    </StackPanel>
                </Grid>
            </controls:SettingsCard>
            <InfoBar
                x:Name="AccountInfoBar"
                Margin="0,4,0,0"
                IsClosable="False"
                IsOpen="True"
                Message="正在检查登录状态..."
                Severity="Informational" />

            <TextBlock
                Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                Text="配置" />
            <controls:SettingsCard
                Description="导出当前通知、启动和登录状态配置。"
                Header="导出配置">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE74E;" />
                </controls:SettingsCard.HeaderIcon>
                <Button
                    x:Name="ExportConfigButton"
                    AutomationProperties.AutomationId="ExportConfigButton"
                    Click="ExportConfigButton_Click"
                    Content="导出" />
            </controls:SettingsCard>
            <controls:SettingsCard
                Description="从 JSON 配置文件恢复通知、启动和登录状态配置。"
                Header="导入配置">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8B5;" />
                </controls:SettingsCard.HeaderIcon>
                <Button
                    x:Name="ImportConfigButton"
                    AutomationProperties.AutomationId="ImportConfigButton"
                    Click="ImportConfigButton_Click"
                    Content="导入" />
            </controls:SettingsCard>
            <TextBlock
                x:Name="ConfigStatusText"
                Margin="1,8,0,0"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
