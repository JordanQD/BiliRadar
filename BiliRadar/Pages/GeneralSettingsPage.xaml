<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BiliRadar.Pages.GeneralSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer
        x:Name="SettingsScrollViewer"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <StackPanel
            Width="560"
            Padding="40,32"
            HorizontalAlignment="Left"
            Spacing="20">
            <TextBlock
                Style="{ThemeResource TitleTextBlockStyle}"
                Text="常规" />

            <StackPanel Spacing="12">
                <TextBlock
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Text="启动与刷新" />
                <ToggleSwitch Header="开机后自动运行" />
                <ToggleSwitch Header="启动时自动刷新" IsOn="True" />
                <NumberBox
                    Width="280"
                    Header="自动刷新间隔（分钟）"
                    HorizontalAlignment="Left"
                    Minimum="1"
                    SpinButtonPlacementMode="Inline"
                    Value="15" />
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Text="通知" />
                <ToggleSwitch Header="发现新动态时显示系统通知" IsOn="True" />
                <ToggleSwitch Header="仅提醒关注列表更新" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
