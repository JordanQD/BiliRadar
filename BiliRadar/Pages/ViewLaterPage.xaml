<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BiliRadar.Pages.ViewLaterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Required">

    <Grid MinHeight="500">
        <ScrollViewer
            x:Name="ViewLaterScrollViewer"
            Padding="10,0,10,0"
            ViewChanged="ViewLaterScrollViewer_ViewChanged"
            VerticalScrollBarVisibility="Auto">
            <StackPanel
                x:Name="ViewLaterCardsPanel"
                Spacing="10">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <AddDeleteThemeTransition />
                        <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="24" IsStaggeringEnabled="True" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>
            </StackPanel>
        </ScrollViewer>

        <StackPanel
            x:Name="ViewLaterEmptyPanel"
            Padding="18,24"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="8"
            Visibility="Collapsed">
            <FontIcon
                HorizontalAlignment="Center"
                FontSize="28"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Glyph="&#xE734;" />
            <TextBlock
                x:Uid="MainViewLaterEmptyTitle"
                HorizontalAlignment="Center"
                FontSize="14"
                FontWeight="SemiBold"
                Text="暂无稍后再看" />
            <TextBlock
                x:Uid="MainViewLaterEmptyDescription"
                HorizontalAlignment="Center"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Text="添加视频后会出现在这里。" />
        </StackPanel>
    </Grid>
</Page>
