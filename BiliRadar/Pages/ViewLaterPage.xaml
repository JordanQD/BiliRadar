<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BiliRadar.Pages.ViewLaterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:BiliRadar.Controls">

    <Grid MinHeight="500">
        <ListView
            x:Name="ViewLaterListView"
            Padding="10,0,10,0"
            HorizontalContentAlignment="Stretch"
            Loaded="ViewLaterListView_Loaded"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,10" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="UseSystemFocusVisuals" Value="False" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <controls:VideoCard
                        Item="{Binding}"
                        Loaded="ViewLaterVideoCard_Loaded"
                        CoverTapped="VideoCard_CoverTapped"
                        CreatorAvatarClicked="VideoCard_CreatorAvatarClicked"
                        ShowMetaTime="False"
                        ViewLaterButtonMode="Remove"
                        ViewLaterClicked="VideoCard_ViewLaterClicked" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel
            x:Name="ViewLaterEmptyPanel"
            Padding="18,24"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="8"
            Visibility="Collapsed">
            <FontIcon
                HorizontalAlignment="Center"
                FontSize="28"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Glyph="&#xE734;" />
            <TextBlock
                x:Uid="MainViewLaterEmptyTitle"
                HorizontalAlignment="Center"
                FontSize="14"
                FontWeight="SemiBold"
                Text="暂无稍后再看" />
            <TextBlock
                x:Uid="MainViewLaterEmptyDescription"
                HorizontalAlignment="Center"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Text="添加视频后会出现在这里。" />
        </StackPanel>
    </Grid>
</Page>
