<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BiliRadar.Pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Required">

    <Grid MinHeight="500">
        <ScrollViewer
            x:Name="HistoryScrollViewer"
            Padding="10,0,10,0"
            ViewChanged="HistoryScrollViewer_ViewChanged"
            VerticalScrollBarVisibility="Auto">
            <StackPanel
                x:Name="HistoryCardsPanel"
                Spacing="10">
                <StackPanel.ChildrenTransitions>
                    <TransitionCollection>
                        <AddDeleteThemeTransition />
                        <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="24" IsStaggeringEnabled="True" />
                    </TransitionCollection>
                </StackPanel.ChildrenTransitions>
            </StackPanel>
        </ScrollViewer>

        <StackPanel
            x:Name="HistoryEmptyPanel"
            Padding="18,24"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="8"
            Visibility="Collapsed">
            <FontIcon
                HorizontalAlignment="Center"
                FontSize="28"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Glyph="&#xE823;" />
            <TextBlock
                x:Uid="MainHistoryEmptyTitle"
                HorizontalAlignment="Center"
                FontSize="14"
                FontWeight="SemiBold"
                Text="暂无历史记录" />
            <TextBlock
                x:Uid="MainHistoryEmptyDescription"
                HorizontalAlignment="Center"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Text="登录后会显示最近看过的视频。" />
        </StackPanel>
    </Grid>
</Page>
