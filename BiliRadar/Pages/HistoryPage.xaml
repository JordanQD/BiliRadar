<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BiliRadar.Pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:BiliRadar.Controls">

    <Grid>
        <ListView
            x:Name="HistoryListView"
            Padding="10,0,10,0"
            HorizontalContentAlignment="Stretch"
            Loaded="HistoryListView_Loaded"
            SelectionMode="None"
            ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,10" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="UseSystemFocusVisuals" Value="False" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <controls:VideoCard
                        Item="{Binding}"
                        Loaded="HistoryVideoCard_Loaded"
                        CoverTapped="VideoCard_CoverTapped"
                        CreatorAvatarClicked="VideoCard_CreatorAvatarClicked"
                        ShowMetaTime="False"
                        ViewLaterButtonMode="Add"
                        ViewLaterClicked="VideoCard_ViewLaterClicked" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel
            x:Name="HistoryEmptyPanel"
            Padding="18,24"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="8"
            Visibility="Collapsed">
            <FontIcon
                HorizontalAlignment="Center"
                FontSize="28"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Glyph="&#xE823;" />
            <TextBlock
                x:Uid="MainHistoryEmptyTitle"
                HorizontalAlignment="Center"
                FontSize="14"
                FontWeight="SemiBold"
                Text="暂无历史记录" />
            <TextBlock
                x:Uid="MainHistoryEmptyDescription"
                HorizontalAlignment="Center"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Text="登录后会显示最近看过的视频。" />
        </StackPanel>
    </Grid>
</Page>
