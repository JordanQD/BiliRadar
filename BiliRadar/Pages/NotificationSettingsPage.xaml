<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BiliRadar.Pages.NotificationSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls">

    <ScrollView
        x:Name="SettingsScrollView"
        Padding="36,32,36,0"
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Auto">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="640" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="SettingsScrollView.Padding" Value="36,32,36,0" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="SettingsScrollView.Padding" Value="12,16,12,16" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <StackPanel
            Margin="0,0,0,32"
            MaxWidth="1064"
            Spacing="{StaticResource SettingsCardSpacing}">
            <StackPanel.ChildrenTransitions>
                <RepositionThemeTransition IsStaggeringEnabled="False" />
            </StackPanel.ChildrenTransitions>

            <TextBlock
                x:Uid="NotificationPageTitle"
                Margin="0,0,0,12"
                Style="{ThemeResource TitleTextBlockStyle}"
                Text="通知" />

            <TextBlock
                x:Uid="NotificationIntervalSectionHeader"
                Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                Text="检查频率" />
            <controls:SettingsCard
                x:Uid="NotificationIntervalCard"
                Description="应用在后台检查动态和直播状态的时间间隔。"
                Header="通知检查间隔（分钟）">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE823;" />
                </controls:SettingsCard.HeaderIcon>
                <NumberBox
                    x:Name="NotificationCheckIntervalBox"
                    x:Uid="NotificationCheckIntervalBox"
                    MinWidth="120"
                    MaxWidth="200"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="NotificationCheckIntervalBox"
                    AutomationProperties.Name="通知检查间隔（分钟）"
                    Minimum="1"
                    SpinButtonPlacementMode="Inline"
                    ValueChanged="NotificationCheckIntervalBox_ValueChanged" />
            </controls:SettingsCard>

            <TextBlock
                x:Uid="NotificationTargetSectionHeader"
                Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                Text="通知对象" />
            <controls:SettingsCard
                x:Uid="NotificationTargetCard"
                Description="选择监听全部关注列表，或只监听手动添加的 UP。"
                Header="通知对象">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE715;" />
                </controls:SettingsCard.HeaderIcon>
                <ComboBox
                    x:Name="NotificationTargetModeBox"
                    x:Uid="NotificationTargetModeBox"
                    MinWidth="160"
                    MaxWidth="300"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.AutomationId="NotificationTargetModeBox"
                    AutomationProperties.Name="通知对象"
                    SelectionChanged="NotificationTargetModeBox_SelectionChanged">
                    <ComboBoxItem x:Uid="NotificationTargetAllFollowingItem" Content="所有 UP 更新" />
                    <ComboBoxItem x:Uid="NotificationTargetCustomCreatorsItem" Content="自定义 UP 通知" />
                </ComboBox>
            </controls:SettingsCard>
            <controls:SettingsCard
                x:Name="GlobalVideoNotificationCard"
                x:Uid="NotificationVideoNotifyCard"
                Description="关注 UP 发布新视频时提醒。"
                Header="视频更新通知">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE714;" />
                </controls:SettingsCard.HeaderIcon>
                <ToggleSwitch
                    x:Name="VideoNotificationSwitch"
                    x:Uid="NotificationVideoNotificationSwitch"
                    AutomationProperties.AutomationId="VideoNotificationSwitch"
                    AutomationProperties.Name="视频更新通知"
                    Toggled="VideoNotificationSwitch_Toggled" />
            </controls:SettingsCard>
            <controls:SettingsCard
                x:Name="GlobalLiveNotificationCard"
                x:Uid="NotificationLiveNotifyCard"
                Description="关注 UP 开始直播时提醒。"
                Header="开播通知">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE789;" />
                </controls:SettingsCard.HeaderIcon>
                <ToggleSwitch
                    x:Name="LiveNotificationSwitch"
                    x:Uid="NotificationLiveNotificationSwitch"
                    AutomationProperties.AutomationId="LiveNotificationSwitch"
                    AutomationProperties.Name="开播通知"
                    Toggled="LiveNotificationSwitch_Toggled" />
            </controls:SettingsCard>

            <StackPanel
                x:Name="CustomNotificationPanel"
                Spacing="{StaticResource SettingsCardSpacing}">
                <TextBlock
                    x:Uid="NotificationCustomSectionHeader"
                    Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                    Text="自定义通知" />
                <controls:SettingsCard
                    x:Uid="NotificationAddCustomCreatorCard"
                    Description="通知通过关注动态流检测，因此仅对你已关注的 UP 生效。"
                    Header="自定义 UP"
                    HorizontalContentAlignment="Right">
                    <controls:SettingsCard.HeaderIcon>
                        <PathIcon Data="M10 2C12.7614 2 15 4.23858 15 7C15 9.76142 12.7614 12 10 12C7.23858 12 5 9.76142 5 7C5 4.23858 7.23858 2 10 2ZM10 3.5C8.067 3.5 6.5 5.067 6.5 7C6.5 8.933 8.067 10.5 10 10.5C11.933 10.5 13.5 8.933 13.5 7C13.5 5.067 11.933 3.5 10 3.5ZM4.25 14H11.25C11.6642 14 12 14.3358 12 14.75C12 15.1642 11.6642 15.5 11.25 15.5H4.25C3.83579 15.5 3.5 15.8358 3.5 16.25V17.16C3.5 17.82 3.79 18.44 4.29 18.86C5.54 19.94 7.44 20.5 10 20.5C10.58 20.5 11.13 20.47 11.65 20.41C12.0615 20.3626 12.4337 20.6579 12.4811 21.0694C12.5285 21.4808 12.2332 21.853 11.8218 21.9004C11.2493 21.9664 10.642 22 10 22C7.11 22 4.87 21.34 3.31 20C2.48 19.29 2 18.25 2 17.16V16.25C2 15.0074 3.00736 14 4.25 14ZM18 12C18.4142 12 18.75 12.3358 18.75 12.75V16.25H22.25C22.6642 16.25 23 16.5858 23 17C23 17.4142 22.6642 17.75 22.25 17.75H18.75V21.25C18.75 21.6642 18.4142 22 18 22C17.5858 22 17.25 21.6642 17.25 21.25V17.75H13.75C13.3358 17.75 13 17.4142 13 17C13 16.5858 13.3358 16.25 13.75 16.25H17.25V12.75C17.25 12.3358 17.5858 12 18 12Z" />
                    </controls:SettingsCard.HeaderIcon>
                    <Button
                        x:Name="AddCreatorButton"
                        x:Uid="NotificationAddCreatorButton"
                        MinWidth="40"
                        Width="40"
                        Height="40"
                        Padding="0"
                        AutomationProperties.AutomationId="AddCreatorButton"
                        AutomationProperties.Name="添加自定义 UP"
                        Click="AddCreatorButton_Click" />
                </controls:SettingsCard>
                <ListView
                        x:Name="CustomNotificationCreatorsList"
                        HorizontalContentAlignment="Stretch"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollMode="Disabled"
                        SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid
                                    HorizontalAlignment="Stretch"
                                    MinHeight="64"
                                    Padding="24,10"
                                    ColumnSpacing="16"
                                    RowSpacing="8">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup>
                                            <VisualState x:Name="WideItem">
                                                <VisualState.StateTriggers>
                                                    <AdaptiveTrigger MinWindowWidth="640" />
                                                </VisualState.StateTriggers>
                                                <VisualState.Setters>
                                                    <Setter Target="ControlsRow.(Grid.Column)" Value="1" />
                                                    <Setter Target="ControlsRow.(Grid.Row)" Value="0" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="NarrowItem">
                                                <VisualState.StateTriggers>
                                                    <AdaptiveTrigger MinWindowWidth="0" />
                                                </VisualState.StateTriggers>
                                                <VisualState.Setters>
                                                    <Setter Target="ControlsRow.(Grid.Column)" Value="0" />
                                                    <Setter Target="ControlsRow.(Grid.Row)" Value="1" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="12">
                                        <PersonPicture
                                            Width="40"
                                            Height="40"
                                            DisplayName="{Binding Name}"
                                            ProfilePicture="{Binding AvatarImage}" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Text="{Binding Name}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel
                                        x:Name="ControlsRow"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="20">
                                        <StackPanel
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <TextBlock
                                                x:Uid="NotificationCustomVideoLabel"
                                                VerticalAlignment="Center"
                                                Text="视频" />
                                            <ToggleSwitch
                                                x:Uid="NotificationCustomVideoSwitch"
                                                AutomationProperties.Name="视频更新通知"
                                                OffContent=""
                                                OnContent=""
                                                IsOn="{Binding VideoNotificationsEnabled, Mode=TwoWay}"
                                                Tag="{Binding}"
                                                Toggled="CustomVideoNotificationSwitch_Toggled" />
                                        </StackPanel>
                                        <StackPanel
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <TextBlock
                                                x:Uid="NotificationCustomLiveLabel"
                                                VerticalAlignment="Center"
                                                Text="开播" />
                                            <ToggleSwitch
                                                x:Uid="NotificationCustomLiveSwitch"
                                                AutomationProperties.Name="开播通知"
                                                OffContent=""
                                                OnContent=""
                                                IsOn="{Binding LiveNotificationsEnabled, Mode=TwoWay}"
                                                Tag="{Binding}"
                                                Toggled="CustomLiveNotificationSwitch_Toggled" />
                                        </StackPanel>
                                        <Button
                                            x:Uid="NotificationRemoveCreatorButton"
                                            Width="36"
                                            Height="36"
                                            Padding="0"
                                            AutomationProperties.Name="删除自定义 UP"
                                            Tag="{Binding}"
                                            Click="RemoveCreatorButton_Click">
                                            <SymbolIcon Symbol="Delete" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                <TextBlock
                    x:Name="CustomNotificationStatusText"
                    Margin="1,8,0,0"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap"
                    Visibility="Collapsed" />
            </StackPanel>
        </StackPanel>
    </ScrollView>
</Page>
