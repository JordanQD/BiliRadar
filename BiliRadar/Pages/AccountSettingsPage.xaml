<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BiliRadar.Pages.AccountSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel
            MaxWidth="720"
            Padding="32,28"
            Spacing="20">
            <TextBlock
                Style="{ThemeResource TitleTextBlockStyle}"
                Text="账号" />

            <StackPanel Spacing="12">
                <TextBlock
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Text="Bilibili 登录状态" />
                <InfoBar
                    IsClosable="False"
                    IsOpen="True"
                    Message="这里预留 Cookie 登录、重新验证和退出登录的位置。"
                    Severity="Informational" />
                <Button Content="管理 Cookie" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
