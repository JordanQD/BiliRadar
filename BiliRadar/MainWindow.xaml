<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BiliRadar.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:BiliRadar.Models"
    Title="BiliRadar">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="RootGrid"
        Width="348"
        MinHeight="100"
        Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="MainContainer"
            Grid.RowSpan="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
        <Grid Padding="16,14,12,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="2">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="BiliRadar" />
                <TextBlock
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind LastCheckedText, Mode=OneWay}" />
            </StackPanel>

            <Button
                Grid.Column="1"
                Width="34"
                Height="34"
                Padding="0"
                Click="RefreshButton_Click"
                Style="{StaticResource SubtleButtonStyle}">
                <FontIcon FontSize="15" Glyph="&#xE72C;" />
            </Button>

            <Button
                Grid.Column="2"
                Width="34"
                Height="34"
                Padding="0"
                Click="HideButton_Click"
                Style="{StaticResource SubtleButtonStyle}">
                <FontIcon FontSize="14" Glyph="&#xE711;" />
            </Button>
        </Grid>

        <Grid Grid.Row="1" Padding="12,4,12,10" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Padding="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="未读更新" />
                    <TextBlock
                        FontSize="26"
                        FontWeight="SemiBold"
                        Text="{x:Bind UnreadCount, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="1"
                Padding="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="关注人数" />
                    <TextBlock
                        FontSize="26"
                        FontWeight="SemiBold"
                        Text="{x:Bind FollowingCount, Mode=OneWay}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Padding="12,0,12,10" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <PasswordBox
                x:Name="CookieBox"
                PlaceholderText="粘贴 B 站 Cookie"
                PasswordRevealMode="Peek" />

            <Grid Grid.Row="1" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind StatusText, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap" />

                <Button
                    Grid.Column="1"
                    MinWidth="64"
                    Click="SaveCookieButton_Click"
                    Content="保存" />

                <Button
                    Grid.Column="2"
                    MinWidth="64"
                    Click="ClearCookieButton_Click"
                    Content="清除" />
            </Grid>
        </Grid>

        <ListView
            Grid.Row="3"
            MinHeight="240"
            MaxHeight="420"
            Padding="6,0"
            ItemsSource="{x:Bind Following, Mode=OneWay}"
            SelectionMode="None">
            <ListView.Header>
                <TextBlock
                    Margin="10,6,0,8"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="关注的人" />
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:CreatorRow">
                    <Grid Padding="8,7" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Width="28"
                            Height="28"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Text="{x:Bind Initial}" />
                        </Border>

                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="{x:Bind Name}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />

                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind Mid}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid
            Grid.Row="4"
            Padding="12,8,12,12"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ProgressRing
                Width="18"
                Height="18"
                HorizontalAlignment="Left"
                IsActive="{x:Bind IsLoading, Mode=OneWay}"
                Visibility="{x:Bind LoadingVisibility, Mode=OneWay}" />

            <Button
                Grid.Column="1"
                MinWidth="92"
                Click="RefreshButton_Click"
                Content="立即刷新" />
        </Grid>
        </Grid>
    </Grid>
</Window>
