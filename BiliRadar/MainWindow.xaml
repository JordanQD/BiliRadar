<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BiliRadar.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:BiliRadar.Models"
    Title="BiliRadar">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="RootGrid"
        Width="420"
        MinHeight="100"
        Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="MainContainer"
            Grid.RowSpan="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
        <Grid Padding="8,8,12,4" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <SelectorBar
                x:Name="ContentSelectorBar"
                SelectionChanged="ContentSelectorBar_SelectionChanged">
                <SelectorBarItem x:Name="FollowingSelectorItem" Text="关注" Icon="Contact" />
                <SelectorBarItem x:Name="HistorySelectorItem" Text="历史" Icon="Clock" />
                <SelectorBarItem x:Name="ViewLaterSelectorItem" Text="稍后再看" Icon="Favorite" />
            </SelectorBar>

            <Button
                Grid.Column="1"
                Width="34"
                Height="34"
                Padding="0"
                Click="OpenBrowserButton_Click"
                Style="{StaticResource SubtleButtonStyle}">
                <FontIcon FontSize="15" Glyph="&#xE774;" />
            </Button>

        </Grid>

        <ScrollViewer
            x:Name="VideoScrollViewer"
            Grid.Row="1"
            MinHeight="500"
            MaxHeight="560"
            Padding="10,0,10,0"
            ViewChanged="VideoScrollViewer_ViewChanged"
            VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="FollowingPagePanel">
                <StackPanel
                    x:Name="LiveCreatorsSection"
                    Margin="0,4,0,10"
                    Spacing="6"
                    Visibility="Collapsed">
                    <TextBlock
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="正在直播" />
                    <ScrollViewer
                        HorizontalScrollBarVisibility="Auto"
                        HorizontalScrollMode="Enabled"
                        VerticalScrollBarVisibility="Disabled"
                        VerticalScrollMode="Disabled"
                        ZoomMode="Disabled">
                        <StackPanel
                            x:Name="LiveCreatorCardsPanel"
                            Orientation="Horizontal"
                            Spacing="10" />
                    </ScrollViewer>
                </StackPanel>
                <StackPanel
                    x:Name="VideoCardsPanel"
                    Spacing="10" />
            </StackPanel>
        </ScrollViewer>

        <Grid
            x:Name="HistoryPagePanel"
            Grid.Row="1"
            MinHeight="500"
            Visibility="Collapsed">
            <ScrollViewer
                x:Name="HistoryScrollViewer"
                MinHeight="500"
                MaxHeight="560"
                Padding="10,0,10,0"
                ViewChanged="HistoryScrollViewer_ViewChanged"
                VerticalScrollBarVisibility="Auto">
                <StackPanel
                    x:Name="HistoryCardsPanel"
                    Spacing="10" />
            </ScrollViewer>

            <StackPanel
                x:Name="HistoryEmptyPanel"
                Padding="18,24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                Visibility="Collapsed">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontSize="28"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Glyph="&#xE823;" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="暂无历史记录" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="登录后会显示最近看过的视频。" />
            </StackPanel>
        </Grid>

        <Grid
            x:Name="ViewLaterPagePanel"
            Grid.Row="1"
            MinHeight="500"
            Visibility="Collapsed">
            <ScrollViewer
                x:Name="ViewLaterScrollViewer"
                MinHeight="500"
                MaxHeight="560"
                Padding="10,0,10,0"
                ViewChanged="ViewLaterScrollViewer_ViewChanged"
                VerticalScrollBarVisibility="Auto">
                <StackPanel
                    x:Name="ViewLaterCardsPanel"
                    Spacing="10" />
            </ScrollViewer>

            <StackPanel
                x:Name="ViewLaterEmptyPanel"
                Padding="18,24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                Visibility="Collapsed">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontSize="28"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Glyph="&#xE734;" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="暂无稍后再看" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="添加视频后会出现在这里。" />
            </StackPanel>
        </Grid>

        <InfoBar
            x:Name="StatusInfoBar"
            Grid.Row="1"
            Margin="12,8,12,12"
            VerticalAlignment="Bottom"
            IsClosable="True"
            IsOpen="{x:Bind IsStatusInfoOpen, Mode=OneWay}"
            Message="{x:Bind StatusText, Mode=OneWay}"
            Severity="{x:Bind StatusSeverity, Mode=OneWay}" />
        </Grid>
    </Grid>
</Window>
