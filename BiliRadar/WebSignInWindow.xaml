<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BiliRadar.WebSignInWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="titleBar"
            x:Uid="WebSignInTitleBar"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="False"
            Title="BiliRadar 登录">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/Square44x44Logo.targetsize-24_altform-unplated.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <Grid Grid.Row="1">
            <WebView2
                x:Name="mainView"
                NavigationCompleted="MainView_NavigationCompleted" />

            <InfoBar
                x:Name="statusInfoBar"
                Margin="16"
                VerticalAlignment="Top"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                IsClosable="True"
                IsOpen="False" />
        </Grid>
    </Grid>
</Window>
