<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         Overlay button brushes — sit on top of cover images.
         ============================================================ -->

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="OverlayButtonBackgroundBrush" Color="#99FFFFFF" />
            <SolidColorBrush x:Key="OverlayButtonBackgroundPointerOverBrush" Color="#E6FFFFFF" />
            <SolidColorBrush x:Key="OverlayButtonBackgroundPressedBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="OverlayButtonBackgroundDisabledBrush" Color="#66FFFFFF" />

            <SolidColorBrush x:Key="OverlayButtonForegroundBrush" Color="#D9000000" />
            <SolidColorBrush x:Key="OverlayButtonForegroundPointerOverBrush" Color="#E6000000" />
            <SolidColorBrush x:Key="OverlayButtonForegroundPressedBrush" Color="#FF000000" />
            <SolidColorBrush x:Key="OverlayButtonForegroundDisabledBrush" Color="#66000000" />

            <SolidColorBrush x:Key="OverlayButtonBorderBrush" Color="#33000000" />
            <SolidColorBrush x:Key="OverlayButtonBorderPointerOverBrush" Color="#66000000" />
            <SolidColorBrush x:Key="OverlayButtonBorderPressedBrush" Color="#80000000" />
            <SolidColorBrush x:Key="OverlayButtonBorderDisabledBrush" Color="#1A000000" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="OverlayButtonBackgroundBrush" Color="#995C5C5C" />
            <SolidColorBrush x:Key="OverlayButtonBackgroundPointerOverBrush" Color="#E6222222" />
            <SolidColorBrush x:Key="OverlayButtonBackgroundPressedBrush" Color="#FF181818" />
            <SolidColorBrush x:Key="OverlayButtonBackgroundDisabledBrush" Color="#66303030" />

            <SolidColorBrush x:Key="OverlayButtonForegroundBrush" Color="#F2FFFFFF" />
            <SolidColorBrush x:Key="OverlayButtonForegroundPointerOverBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="OverlayButtonForegroundPressedBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="OverlayButtonForegroundDisabledBrush" Color="#66FFFFFF" />

            <SolidColorBrush x:Key="OverlayButtonBorderBrush" Color="#50FFFFFF" />
            <SolidColorBrush x:Key="OverlayButtonBorderPointerOverBrush" Color="#87FFFFFF" />
            <SolidColorBrush x:Key="OverlayButtonBorderPressedBrush" Color="#B4FFFFFF" />
            <SolidColorBrush x:Key="OverlayButtonBorderDisabledBrush" Color="#26FFFFFF" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="HighContrast">
            <StaticResource x:Key="OverlayButtonBackgroundBrush" ResourceKey="SystemColorButtonFaceColorBrush" />
            <StaticResource x:Key="OverlayButtonBackgroundPointerOverBrush" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="OverlayButtonBackgroundPressedBrush" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="OverlayButtonBackgroundDisabledBrush" ResourceKey="SystemColorButtonFaceColorBrush" />

            <StaticResource x:Key="OverlayButtonForegroundBrush" ResourceKey="SystemColorButtonTextColorBrush" />
            <StaticResource x:Key="OverlayButtonForegroundPointerOverBrush" ResourceKey="SystemColorHighlightTextColorBrush" />
            <StaticResource x:Key="OverlayButtonForegroundPressedBrush" ResourceKey="SystemColorHighlightTextColorBrush" />
            <StaticResource x:Key="OverlayButtonForegroundDisabledBrush" ResourceKey="SystemColorGrayTextColorBrush" />

            <StaticResource x:Key="OverlayButtonBorderBrush" ResourceKey="SystemColorButtonTextColorBrush" />
            <StaticResource x:Key="OverlayButtonBorderPointerOverBrush" ResourceKey="SystemColorHighlightTextColorBrush" />
            <StaticResource x:Key="OverlayButtonBorderPressedBrush" ResourceKey="SystemColorHighlightTextColorBrush" />
            <StaticResource x:Key="OverlayButtonBorderDisabledBrush" ResourceKey="SystemColorGrayTextColorBrush" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- ============================================================
         Duration badge — always dark, on top of cover images.
         ============================================================ -->

    <SolidColorBrush x:Key="DurationBadgeBackgroundBrush" Color="#B4000000" />
    <SolidColorBrush x:Key="DurationBadgeForegroundBrush" Color="#FFFFFF" />

    <!-- ============================================================
         Settings page shared styles.
         ============================================================ -->

    <x:Double x:Key="SettingsCardSpacing">4</x:Double>

    <Style
        x:Key="SettingsSectionHeaderTextBlockStyle"
        BasedOn="{StaticResource BodyStrongTextBlockStyle}"
        TargetType="TextBlock">
        <Setter Property="Margin" Value="1,36,0,8" />
    </Style>

</ResourceDictionary>
