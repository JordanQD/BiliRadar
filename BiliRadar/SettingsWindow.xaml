<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BiliRadar.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.Resources>
            <x:Double x:Key="TitleBarPaneToggleButtonWidth">48</x:Double>
            <x:Double x:Key="TitleBarIconMaxWidth">20</x:Double>
            <x:Double x:Key="TitleBarIconMaxHeight">20</x:Double>
            <Thickness x:Key="TitleBarIconMargin">0,0,12,0</Thickness>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="titleBar"
            Title="BiliRadar"
            Subtitle=""
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/Square44x44Logo.targetsize-24_altform-unplated.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="navView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            CompactPaneLength="48"
            OpenPaneLength="220"
            PaneDisplayMode="Left"
            SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="GeneralNavItem"
                    x:Uid="SettingsGeneralNavItem"
                    Content="通用"
                    Icon="Setting"
                    Tag="general" />
                <NavigationViewItem
                    x:Uid="SettingsNotificationNavItem"
                    Content="通知"
                    Icon="Message"
                    Tag="notification" />
                <NavigationViewItem
                    x:Uid="SettingsAboutNavItem"
                    Content="关于"
                    Icon="Help"
                    Tag="about" />
            </NavigationView.MenuItems>

            <Frame
                x:Name="navFrame" />
        </NavigationView>
    </Grid>
</Window>
